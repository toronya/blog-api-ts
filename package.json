{
  "name": "20260228_blogapi",
  "version": "1.0.0",
  "description": "A lightweight TypeScript blog API with full CRUD operations and search functionality, built with Hono and SQLite",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:stop": "lsof -ti:3000 | xargs kill -9 || true",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "dev:all": "pnpm dev & pnpm --filter @blog/bff dev & pnpm --filter @blog/frontend dev",
    "dev:bff": "pnpm --filter @blog/bff dev",
    "dev:front": "pnpm --filter @blog/frontend dev"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@libsql/client": "^0.17.0",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.3"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
